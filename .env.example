# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# Optional External Agent Configuration
# EXTERNAL_AGENT_NAME: Friendly name of the agent
EXTERNAL_AGENT_NAME="Premium Signal Agent"
# EXTERNAL_AGENT_API_KEY: Secure API key for the agent
EXTERNAL_AGENT_API_KEY="AGENT_SECRET_KEY"
# EXTERNAL_AGENT_ENDPOINT: URL endpoint for the agent
EXTERNAL_AGENT_ENDPOINT="https://api.externalagent.com/v1"

# Premium 1-Minute Financial Data Feeds (Optional fallback if not entered in UI)
POLYGON_API_KEY=
TWELVE_DATA_API_KEY=
OANDA_API_KEY=
MASSIVE_API_KEY=
CUSTOM_BROKER_API_GATEWAY=

# Multi-Agent Language Model Keys
GROQ_API_KEY=
SAMBANOVA_API_KEY=



